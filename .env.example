# Google Sheets (optional)
GOOGLE_SHEETS_CREDENTIALS_JSON=path/to/credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id

# Proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=

# Scraper settings
MAX_PAGES=9
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
LOG_LEVEL=INFO

# Enricher (Google Maps) settings
MAPS_DELAY_MIN=4
MAPS_DELAY_MAX=9

# Brevo API (email sending)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=you@yourdomain.com
BREVO_SENDER_NAME=YourName

# IMAP (reply detection — optional but recommended)
# Gmail: imap.gmail.com / Outlook: outlook.office365.com
IMAP_HOST=imap.yourmailhost.com
IMAP_PORT=993
IMAP_USER=you@yourdomain.com
IMAP_PASSWORD=your_imap_password
